# =============================================================================
#  Verifyr — .gitignore
#  Health-tech wearable AI advisor · FastAPI · Qdrant · Claude · Supabase
# =============================================================================


# -----------------------------------------------------------------------------
#  Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python


# -----------------------------------------------------------------------------
#  Virtual Environment & Dependencies
# -----------------------------------------------------------------------------
venv/
env/
ENV/
requirements.txt


# -----------------------------------------------------------------------------
#  Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.figma
backend/system_prompt.txt


# -----------------------------------------------------------------------------
#  Data — Raw & Processed (too large / proprietary)
# -----------------------------------------------------------------------------
data/raw/*.pdf
data/processed/*.json
data/processed/*.pkl
data/qdrant_storage/


# -----------------------------------------------------------------------------
#  Logs
# -----------------------------------------------------------------------------
*.log
backend/server.log


# -----------------------------------------------------------------------------
#  IDEs & Editors
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.claude/
CLAUDE.md


# -----------------------------------------------------------------------------
#  OS
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db


# -----------------------------------------------------------------------------
#  Documentation (internal only)
# -----------------------------------------------------------------------------
docs/


# -----------------------------------------------------------------------------
#  Local-only Files
# -----------------------------------------------------------------------------
architecture-portfolio.html
verifyr_system_design.html
.env.example
